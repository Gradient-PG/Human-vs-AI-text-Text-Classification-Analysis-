\newlabel{tab:per-cell}{{10}{17}{Per-cell L2-probe metrics for all six generators. Each block of 15 rows is one generator; columns are seed and fold index. Acc: accuracy; AUC: AUC-ROC; $n_{\text {sel}}$: neurons selected by L1 in this cell}{table.caption.38}{}}
\@writefile{lot}{\contentsline {table}{\numberline {11}{\ignorespaces L1 vs.\ AUC selection: mean across 15 cells. $n$: features selected. Jaccard: overlap between the two selection sets. Drop: accuracy drop from baseline when complement is ablated (positive = degradation). Three regimes are visible: parsimony (GPT-4, Mistral, LLaMA --- L1 selects far fewer features with equivalent or smaller drop), convergence (GPT-2 --- similar $n$, similar drop), and reversal (Cohere --- AUC selects fewer with smaller drop).}}{18}{table.caption.39}\protected@file@percent }
\newlabel{tab:auc-l1}{{11}{18}{L1 vs.\ AUC selection: mean across 15 cells. $n$: features selected. Jaccard: overlap between the two selection sets. Drop: accuracy drop from baseline when complement is ablated (positive = degradation). Three regimes are visible: parsimony (GPT-4, Mistral, LLaMA --- L1 selects far fewer features with equivalent or smaller drop), convergence (GPT-2 --- similar $n$, similar drop), and reversal (Cohere --- AUC selects fewer with smaller drop)}{table.caption.39}{}}
\@writefile{lot}{\contentsline {table}{\numberline {12}{\ignorespaces Per-domain selected flip rate (\%) at $k = \text  {full}$, 15-cell means. Domain means may differ slightly from the overall mean due to variation in the number of valid-human pairs per domain. GPT-2 shows elevated flip rates on news, Reddit, and wiki (3.1--4.9\%) relative to books and reviews (1.9--2.0\%), suggesting its detection signal is stronger in formal or community text domains. Cohere is uniformly high across all six domains (5.5--10.1\%), consistent with its proximity to the probe decision boundary overall. Mistral shows a notable wiki spike (3.54\%) while reviews are weak (0.62\%). }}{19}{table.caption.40}\protected@file@percent }
\newlabel{tab:perdomain}{{12}{19}{Per-domain selected flip rate (\%) at $k = \text {full}$, 15-cell means. Domain means may differ slightly from the overall mean due to variation in the number of valid-human pairs per domain. GPT-2 shows elevated flip rates on news, Reddit, and wiki (3.1--4.9\%) relative to books and reviews (1.9--2.0\%), suggesting its detection signal is stronger in formal or community text domains. Cohere is uniformly high across all six domains (5.5--10.1\%), consistent with its proximity to the probe decision boundary overall. Mistral shows a notable wiki spike (3.54\%) while reviews are weak (0.62\%)}{table.caption.40}{}}
