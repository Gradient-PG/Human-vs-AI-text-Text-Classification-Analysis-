\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Overview of the experimental pipeline. Frozen BERT-base-uncased\xspace  CLS activations are concatenated across all 12 layers, yielding $\mathbf  {z}\in \mathbb  {R}^{9{,}216}$. An L1-regularised probe ($C\!=\!0.005$) selects a sparse candidate set per (fold, seed) cell; neurons stable in ${\geq }50\%$ of all 15 cells become the \textit  {stable set}~$\mathcal  {S}$ (45--62 neurons per generator). An independent L2 probe trained on all 9{,}216 neurons is frozen and reused as the decision function in both experiments. \textbf  {Left branch} (\S  \ref {sec:results-necessity}): mean ablation tests necessity (accuracy drops $\leq \!1.2$\,pp on 5/6 generators). \textbf  {Right branch} (\S  \ref {sec:results-patching}): activation patching tests causal sufficiency: 1--8\% of human samples flip to AI, $10\text  {--}16\times $ above a random baseline.}}{13}{figure.caption.21}\protected@file@percent }
\newlabel{fig:pipeline}{{4}{13}{Overview of the experimental pipeline. Frozen \bertbase CLS activations are concatenated across all 12 layers, yielding $\mathbf {z}\in \mathbb {R}^{9{,}216}$. An L1-regularised probe ($C\!=\!0.005$) selects a sparse candidate set per (fold, seed) cell; neurons stable in ${\geq }50\%$ of all 15 cells become the \textit {stable set}~$\mathcal {S}$ (45--62 neurons per generator). An independent L2 probe trained on all 9{,}216 neurons is frozen and reused as the decision function in both experiments. \textbf {Left branch} (\S \ref {sec:results-necessity}): mean ablation tests necessity (accuracy drops $\leq \!1.2$\,pp on 5/6 generators). \textbf {Right branch} (\S \ref {sec:results-patching}): activation patching tests causal sufficiency: 1--8\% of human samples flip to AI, $10\text {--}16\times $ above a random baseline}{figure.caption.21}{}}
