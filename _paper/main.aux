\citation{kim2018tcav}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Overview of the experimental pipeline. Frozen BERT-base-uncased\xspace  CLS activations are concatenated across all 12 layers, yielding $\mathbf  {z}\in \mathbb  {R}^{9{,}216}$. An L1-regularised probe ($C\!=\!0.005$) selects a sparse candidate set per (fold, seed) cell; neurons stable in ${\geq }50\%$ of all 15 cells become the \textit  {stable set}~$\mathcal  {S}$ (45--62 neurons per generator). An independent L2 probe trained on all 9{,}216 features is frozen and reused as the decision function in both experiments. \textbf  {Left branch} (\S  \ref {sec:results-necessity}): $\mathcal  {S}$ activations are replaced with their training mean (\textit  {mean ablation}), testing \textit  {necessity} --- accuracy drops by $\leq \!1.2$\,pp on 5 of 6 generators, indicating the signal is redundantly distributed. \textbf  {Right branch} (\S  \ref {sec:results-patching}): $\mathcal  {S}$ activations are transplanted from a same-domain AI donor into a human sample (\textit  {activation patching}), testing \textit  {causal sufficiency} --- 1--8\% of human samples flip to AI predictions, $10\text  {--}16\times $ above a random-neuron baseline.}}{5}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:pipeline}{{1}{5}{Overview of the experimental pipeline. Frozen \bertbase CLS activations are concatenated across all 12 layers, yielding $\mathbf {z}\in \mathbb {R}^{9{,}216}$. An L1-regularised probe ($C\!=\!0.005$) selects a sparse candidate set per (fold, seed) cell; neurons stable in ${\geq }50\%$ of all 15 cells become the \textit {stable set}~$\mathcal {S}$ (45--62 neurons per generator). An independent L2 probe trained on all 9{,}216 features is frozen and reused as the decision function in both experiments. \textbf {Left branch} (\S \ref {sec:results-necessity}): $\mathcal {S}$ activations are replaced with their training mean (\textit {mean ablation}), testing \textit {necessity} --- accuracy drops by $\leq \!1.2$\,pp on 5 of 6 generators, indicating the signal is redundantly distributed. \textbf {Right branch} (\S \ref {sec:results-patching}): $\mathcal {S}$ activations are transplanted from a same-domain AI donor into a human sample (\textit {activation patching}), testing \textit {causal sufficiency} --- 1--8\% of human samples flip to AI predictions, $10\text {--}16\times $ above a random-neuron baseline}{figure.caption.2}{}}
