\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Leave-one-family-out (LOGO) generalisation. $n_{\text  {stable}}$: stable neurons identified from the four training families. Full\,L2: L2-probe accuracy using all 9{,}216 BERT neurons. Sel\,L2: L2-probe accuracy restricted to $n_{\text  {stable}}$ neurons. Sel/Full: ratio expressing how much of the full-feature ceiling the selected neurons retain. Full AUC: area under the ROC curve (AUC) for the full-feature L2 probe. Sel AUC: AUC for the Sel\,L2 probe, ranging from 0.863 (cohere) to 0.986 (llama). All metrics are means over 3 seeds $\times $ 5 folds = 15 cells. Test set sizes: 5{,}000 (llama, 1 generator) to 20{,}000 (gpt, 4 generators). }}{8}{table.caption.11}\protected@file@percent }
\newlabel{tab:logo}{{4}{8}{Leave-one-family-out (LOGO) generalisation. $n_{\text {stable}}$: stable neurons identified from the four training families. Full\,L2: L2-probe accuracy using all 9{,}216 BERT neurons. Sel\,L2: L2-probe accuracy restricted to $n_{\text {stable}}$ neurons. Sel/Full: ratio expressing how much of the full-feature ceiling the selected neurons retain. Full AUC: area under the ROC curve (AUC) for the full-feature L2 probe. Sel AUC: AUC for the Sel\,L2 probe, ranging from 0.863 (cohere) to 0.986 (llama). All metrics are means over 3 seeds $\times $ 5 folds = 15 cells. Test set sizes: 5{,}000 (llama, 1 generator) to 20{,}000 (gpt, 4 generators)}{table.caption.11}{}}
