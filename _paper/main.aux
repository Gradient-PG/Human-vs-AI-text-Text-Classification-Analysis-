\@writefile{lot}{\contentsline {table}{\numberline {10}{\ignorespaces Per-domain selected flip rate (\%) at $k = \text  {full}$, 15-cell means. Domain means may differ slightly from the overall mean due to variation in the number of valid-human pairs per domain. GPT-2 shows elevated flip rates on news, Reddit, and wiki (3.1--4.9\%) relative to books and reviews (1.9--2.0\%), which suggests its detection signal is stronger in formal or community text domains. Cohere is uniformly high across all six domains (5.5--10.1\%), because its probe operates near the decision boundary throughout. Mistral shows a notable wiki spike (3.54\%) while reviews are weak (0.62\%).}}{18}{table.caption.37}\protected@file@percent }
\newlabel{tab:perdomain}{{10}{18}{Per-domain selected flip rate (\%) at $k = \text {full}$, 15-cell means. Domain means may differ slightly from the overall mean due to variation in the number of valid-human pairs per domain. GPT-2 shows elevated flip rates on news, Reddit, and wiki (3.1--4.9\%) relative to books and reviews (1.9--2.0\%), which suggests its detection signal is stronger in formal or community text domains. Cohere is uniformly high across all six domains (5.5--10.1\%), because its probe operates near the decision boundary throughout. Mistral shows a notable wiki spike (3.54\%) while reviews are weak (0.62\%)}{table.caption.37}{}}
\@writefile{lot}{\contentsline {table}{\numberline {11}{\ignorespaces Stable-neuron counts by layer group across six generators. Bold indicates the peak layer group for each generator. Instruction-tuned generators (GPT-4, Mistral, LLaMA, Cohere) concentrate 30--36\% of stable neurons in layer~12; both pure-base generators (GPT-2, MPT) have $\leq $14\% in layer~12.}}{18}{table.caption.38}\protected@file@percent }
\newlabel{tab:layer-dist}{{11}{18}{Stable-neuron counts by layer group across six generators. Bold indicates the peak layer group for each generator. Instruction-tuned generators (GPT-4, Mistral, LLaMA, Cohere) concentrate 30--36\% of stable neurons in layer~12; both pure-base generators (GPT-2, MPT) have $\leq $14\% in layer~12}{table.caption.38}{}}
\@writefile{lot}{\contentsline {table}{\numberline {12}{\ignorespaces Pairwise Jaccard similarity between stable sets (15 generator pairs). $\times $\,chance is observed Jaccard divided by the analytic random-null Jaccard for two sets of the same sizes drawn from 9,216 neurons ($\approx $0.003 per pair). The mpt--gpt2 pair (bold) is the highest base$\times $base overlap; all base$\times $instruction-tuned pairs cluster at the bottom.}}{18}{table.caption.40}\protected@file@percent }
\newlabel{tab:jaccard}{{12}{18}{Pairwise Jaccard similarity between stable sets (15 generator pairs). $\times $\,chance is observed Jaccard divided by the analytic random-null Jaccard for two sets of the same sizes drawn from 9,216 neurons ($\approx $0.003 per pair). The mpt--gpt2 pair (bold) is the highest base$\times $base overlap; all base$\times $instruction-tuned pairs cluster at the bottom}{table.caption.40}{}}
\def\@LN@column{2}
\@writefile{lot}{\contentsline {table}{\numberline {13}{\ignorespaces Flip rate (\%) for both patching directions, 15-cell means (5 folds $\times $ 3 seeds). $k = \text  {full}$ equals each cell's actual $|\mathcal  {S}|$ (53--92 neurons); std shown only for $k = \text  {full}$. \textbf  {Forward direction} (AI donor $\to $ human target) provides the $k$-sweep and is monotonically increasing in $k$ for every generator. \textbf  {Reverse direction} (human donor $\to $ AI target) was evaluated only at $k = \text  {full}$; rates are consistently 7--12$\times $ above the random-$k$ baseline and lower than the forward direction, consistent with the partial redundancy interpretation in §\ref {sec:patching-results}.}}{19}{table.caption.41}\protected@file@percent }
\newlabel{tab:patching-sweep}{{13}{19}{Flip rate (\%) for both patching directions, 15-cell means (5 folds $\times $ 3 seeds). $k = \text {full}$ equals each cell's actual $|\mathcal {S}|$ (53--92 neurons); std shown only for $k = \text {full}$. \textbf {Forward direction} (AI donor $\to $ human target) provides the $k$-sweep and is monotonically increasing in $k$ for every generator. \textbf {Reverse direction} (human donor $\to $ AI target) was evaluated only at $k = \text {full}$; rates are consistently 7--12$\times $ above the random-$k$ baseline and lower than the forward direction, consistent with the partial redundancy interpretation in §\ref {sec:patching-results}}{table.caption.41}{}}
