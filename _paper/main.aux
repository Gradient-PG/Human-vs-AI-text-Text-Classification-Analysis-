\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Mean Jaccard stability (and mean $\bar  {n}$ selected) across 15 random draws of the L1 selector. Rows are $C$ values; columns are $N$ values. Larger Jaccard is better. \textbf  {Bold}: chosen operating point ($C=0.005$, $N=7{,}500$). Dagger ($\dagger $): degenerate cell ($\bar  {n}<1$, Jaccard trivially 1.0 or unstable). $N=10{,}000$ omitted (only $K=1$ draw possible; pool exhausted).}}{14}{table.caption.32}\protected@file@percent }
\newlabel{tab:stability-grid}{{5}{14}{Mean Jaccard stability (and mean $\bar {n}$ selected) across 15 random draws of the L1 selector. Rows are $C$ values; columns are $N$ values. Larger Jaccard is better. \textbf {Bold}: chosen operating point ($C=0.005$, $N=7{,}500$). Dagger ($\dagger $): degenerate cell ($\bar {n}<1$, Jaccard trivially 1.0 or unstable). $N=10{,}000$ omitted (only $K=1$ draw possible; pool exhausted)}{table.caption.32}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Per-cell L2-probe metrics for all six generators. Each block of 15 rows is one generator; columns are seed and fold index. Acc: accuracy; AUC: AUC-ROC; $n_{\text  {sel}}$: neurons selected by L1 in this cell.}}{15}{table.caption.33}\protected@file@percent }
\newlabel{tab:per-cell}{{6}{15}{Per-cell L2-probe metrics for all six generators. Each block of 15 rows is one generator; columns are seed and fold index. Acc: accuracy; AUC: AUC-ROC; $n_{\text {sel}}$: neurons selected by L1 in this cell}{table.caption.33}{}}
