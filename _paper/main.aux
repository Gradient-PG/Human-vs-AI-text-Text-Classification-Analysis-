\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Mean Jaccard stability (and mean $\bar  {n}$ selected) across 15 random draws of the L1 selector. Rows are $C$ values; columns are $N$ values. Larger Jaccard is better. \textbf  {Bold}: chosen operating point ($C=0.005$, $N=7{,}500$). Dagger ($\dagger $): degenerate cell ($\bar  {n}<1$, Jaccard trivially 1.0 or unstable). $N=10{,}000$ omitted (only $K=1$ draw possible; pool exhausted).}}{15}{table.caption.30}\protected@file@percent }
\newlabel{tab:stability-grid}{{5}{15}{Mean Jaccard stability (and mean $\bar {n}$ selected) across 15 random draws of the L1 selector. Rows are $C$ values; columns are $N$ values. Larger Jaccard is better. \textbf {Bold}: chosen operating point ($C=0.005$, $N=7{,}500$). Dagger ($\dagger $): degenerate cell ($\bar {n}<1$, Jaccard trivially 1.0 or unstable). $N=10{,}000$ omitted (only $K=1$ draw possible; pool exhausted)}{table.caption.30}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Per-cell L2-probe metrics for all six generators. Each block of 15 rows is one generator; columns are seed and fold index. Acc: accuracy; AUC: AUC-ROC; $n_{\text  {sel}}$: neurons selected by L1 in this cell.}}{16}{table.caption.31}\protected@file@percent }
\newlabel{tab:per-cell}{{6}{16}{Per-cell L2-probe metrics for all six generators. Each block of 15 rows is one generator; columns are seed and fold index. Acc: accuracy; AUC: AUC-ROC; $n_{\text {sel}}$: neurons selected by L1 in this cell}{table.caption.31}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces L1 vs.\ AUC selection: mean across 15 cells. $n$: neurons selected. Jaccard: overlap between the two selection sets. Drop: accuracy drop from baseline when complement is ablated (positive = degradation). Three regimes are visible: parsimony (GPT-4, Mistral, LLaMA: L1 selects far fewer neurons with equivalent or smaller drop), convergence (GPT-2, similar $n$ and similar drop), and reversal (Cohere: AUC selects fewer with smaller drop).}}{17}{table.caption.32}\protected@file@percent }
\newlabel{tab:auc-l1}{{7}{17}{L1 vs.\ AUC selection: mean across 15 cells. $n$: neurons selected. Jaccard: overlap between the two selection sets. Drop: accuracy drop from baseline when complement is ablated (positive = degradation). Three regimes are visible: parsimony (GPT-4, Mistral, LLaMA: L1 selects far fewer neurons with equivalent or smaller drop), convergence (GPT-2, similar $n$ and similar drop), and reversal (Cohere: AUC selects fewer with smaller drop)}{table.caption.32}{}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Restricted probe results. \textit  {Smaller model}: L2 probe retrained on only the $|\mathcal  {S}|$ stable neurons. \textit  {Gap}: smaller-model accuracy minus ablate-complement accuracy (positive = stable neurons self-sufficient; larger = more dependence on non-stable neurons in the full-feature probe). 15-cell means $\pm $ std.}}{17}{table.caption.33}\protected@file@percent }
\newlabel{tab:restricted-probe}{{8}{17}{Restricted probe results. \textit {Smaller model}: L2 probe retrained on only the $|\mathcal {S}|$ stable neurons. \textit {Gap}: smaller-model accuracy minus ablate-complement accuracy (positive = stable neurons self-sufficient; larger = more dependence on non-stable neurons in the full-feature probe). 15-cell means $\pm $ std}{table.caption.33}{}}
\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces CAV diagnostics on per-generator stable sets. All values mean\,$\pm $\,std across 3 random seeds. Cosine: similarity between mean-difference CAV and L1 probe weight. LR acc: logistic-regression accuracy on the CAV projection. $\|\Delta \mu \|$: AI\,$-$\,human mean-difference norm (deterministic; bold\,=\,largest). $\|w\|$: L1 weight norm (bold\,=\,smallest).}}{17}{table.caption.34}\protected@file@percent }
\newlabel{tab:cav}{{9}{17}{CAV diagnostics on per-generator stable sets. All values mean\,$\pm $\,std across 3 random seeds. Cosine: similarity between mean-difference CAV and L1 probe weight. LR acc: logistic-regression accuracy on the CAV projection. $\|\Delta \mu \|$: AI\,$-$\,human mean-difference norm (deterministic; bold\,=\,largest). $\|w\|$: L1 weight norm (bold\,=\,smallest)}{table.caption.34}{}}
\@writefile{lot}{\contentsline {table}{\numberline {10}{\ignorespaces Per-domain selected flip rate (\%) at $k = \text  {full}$, 15-cell means. Domain means may differ slightly from the overall mean due to variation in the number of valid-human pairs per domain. GPT-2 shows elevated flip rates on news, Reddit, and wiki (3.1--4.9\%) relative to books and reviews (1.9--2.0\%), suggesting its detection signal is stronger in formal or community text domains. Cohere is uniformly high across all six domains (5.5--10.1\%), consistent with its proximity to the probe decision boundary overall. Mistral shows a notable wiki spike (3.54\%) while reviews are weak (0.62\%). }}{18}{table.caption.35}\protected@file@percent }
\newlabel{tab:perdomain}{{10}{18}{Per-domain selected flip rate (\%) at $k = \text {full}$, 15-cell means. Domain means may differ slightly from the overall mean due to variation in the number of valid-human pairs per domain. GPT-2 shows elevated flip rates on news, Reddit, and wiki (3.1--4.9\%) relative to books and reviews (1.9--2.0\%), suggesting its detection signal is stronger in formal or community text domains. Cohere is uniformly high across all six domains (5.5--10.1\%), consistent with its proximity to the probe decision boundary overall. Mistral shows a notable wiki spike (3.54\%) while reviews are weak (0.62\%)}{table.caption.35}{}}
\@writefile{lot}{\contentsline {table}{\numberline {11}{\ignorespaces Stable-neuron counts by layer group across six generators. Bold indicates the peak layer group for each generator. Instruction-tuned generators (GPT-4, Mistral, LLaMA, Cohere) concentrate 30--36\% of stable neurons in layer~12; both pure-base generators (GPT-2, MPT) have $\leq $14\% in layer~12. }}{18}{table.caption.36}\protected@file@percent }
\newlabel{tab:layer-dist}{{11}{18}{Stable-neuron counts by layer group across six generators. Bold indicates the peak layer group for each generator. Instruction-tuned generators (GPT-4, Mistral, LLaMA, Cohere) concentrate 30--36\% of stable neurons in layer~12; both pure-base generators (GPT-2, MPT) have $\leq $14\% in layer~12}{table.caption.36}{}}
\@writefile{lot}{\contentsline {table}{\numberline {12}{\ignorespaces Pairwise Jaccard similarity between stable sets (15 generator pairs). $\times $\,chance is observed Jaccard divided by the analytic random-null Jaccard for two sets of the same sizes drawn from 9,216 neurons ($\approx $0.003 per pair). The mpt--gpt2 pair (bold) is the highest base$\times $base overlap; all base$\times $instruction-tuned pairs cluster at the bottom. }}{18}{table.caption.37}\protected@file@percent }
\newlabel{tab:jaccard}{{12}{18}{Pairwise Jaccard similarity between stable sets (15 generator pairs). $\times $\,chance is observed Jaccard divided by the analytic random-null Jaccard for two sets of the same sizes drawn from 9,216 neurons ($\approx $0.003 per pair). The mpt--gpt2 pair (bold) is the highest base$\times $base overlap; all base$\times $instruction-tuned pairs cluster at the bottom}{table.caption.37}{}}
\@writefile{lot}{\contentsline {table}{\numberline {13}{\ignorespaces Selected flip rate (\%) across the $k$-sweep, 15-cell means (5 folds $\times $ 3 seeds). $k = \text  {full}$ equals each cell's actual $|\mathcal  {S}|$ (53--92 neurons); std shown only for $k = \text  {full}$. Flip rate is monotonically increasing in $k$ for every generator. }}{19}{table.caption.38}\protected@file@percent }
