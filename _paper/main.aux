\newlabel{sec:crossgen-cav}{{4.2}{5}{Detection Signal Geometry}{subsection.4.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Sparse-probe results across six generators: 15-cell means $\pm $ std (5 folds $\times $ 3 seeds). Val acc: L2 evaluation probe accuracy (all 9{,}216 features). AUC: area under the ROC curve. $n_{\text  {sel}}\xspace  $: mean candidate set size per cell. Jaccard: mean pairwise fold Jaccard over all 105 fold-pairs (C(15,2)), computed from per-fold selection sets. $n_{\text  {stable}}$: neurons in $\geq $50\% of cells; $n_{\text  {obs}}$: total distinct neurons selected at least once. }}{5}{table.caption.3}\protected@file@percent }
\newlabel{tab:sparse-summary}{{1}{5}{Sparse-probe results across six generators: 15-cell means $\pm $ std (5 folds $\times $ 3 seeds). Val acc: L2 evaluation probe accuracy (all 9{,}216 features). AUC: area under the ROC curve. $\nselected $: mean candidate set size per cell. Jaccard: mean pairwise fold Jaccard over all 105 fold-pairs (C(15,2)), computed from per-fold selection sets. $n_{\text {stable}}$: neurons in $\geq $50\% of cells; $n_{\text {obs}}$: total distinct neurons selected at least once}{table.caption.3}{}}
\citation{heimersheim2024patching}
\citation{heimersheim2024patching}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces CAV diagnostics on per-generator stable sets. All values mean\,$\pm $\,std across 3 random seeds. Cosine: similarity between mean-difference CAV and L1 probe weight. LR acc: logistic-regression accuracy on the CAV projection. $\|\Delta \mu \|$: AI\,$-$\,human mean-difference norm (deterministic; bold\,=\,largest). $\|w\|$: L1 weight norm (bold\,=\,smallest). }}{6}{table.caption.4}\protected@file@percent }
\newlabel{tab:cav}{{2}{6}{CAV diagnostics on per-generator stable sets. All values mean\,$\pm $\,std across 3 random seeds. Cosine: similarity between mean-difference CAV and L1 probe weight. LR acc: logistic-regression accuracy on the CAV projection. $\|\Delta \mu \|$: AI\,$-$\,human mean-difference norm (deterministic; bold\,=\,largest). $\|w\|$: L1 weight norm (bold\,=\,smallest)}{table.caption.4}{}}
