\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Overview of the experimental pipeline. Frozen BERT-base-uncased\xspace  CLS activations are concatenated across all 12 layers, yielding $\mathbf  {z}\in \mathbb  {R}^{9{,}216}$. An L1-regularised probe ($C\!=\!0.005$) selects a sparse candidate set per (fold, seed) cell; neurons stable in ${\geq }50\%$ of all 15 cells become the \textit  {stable set}~$\mathcal  {S}$ (45--62 neurons per generator). An independent L2 probe trained on all 9{,}216 neurons is frozen and reused as the decision function in both experiments. \textbf  {Left branch} (\S  \ref {sec:results-necessity}): mean ablation ($\leq \!0.11$\,pp drop on 5/6 generators; 1.06\,pp Cohere). \textbf  {Right branch} (\S  \ref {sec:results-patching}): bidirectional activation patching: forward (AI $\to $ human) flips 1--8\% of human samples to AI, $10\text  {--}16\times $ above random; reverse (human $\to $ AI) flips 0.65--5.74\% of AI samples to human, $7\text  {--}12\times $ above random.}}{2}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:pipeline}{{1}{2}{Overview of the experimental pipeline. Frozen \bertbase CLS activations are concatenated across all 12 layers, yielding $\mathbf {z}\in \mathbb {R}^{9{,}216}$. An L1-regularised probe ($C\!=\!0.005$) selects a sparse candidate set per (fold, seed) cell; neurons stable in ${\geq }50\%$ of all 15 cells become the \textit {stable set}~$\mathcal {S}$ (45--62 neurons per generator). An independent L2 probe trained on all 9{,}216 neurons is frozen and reused as the decision function in both experiments. \textbf {Left branch} (\S \ref {sec:results-necessity}): mean ablation ($\leq \!0.11$\,pp drop on 5/6 generators; 1.06\,pp Cohere). \textbf {Right branch} (\S \ref {sec:results-patching}): bidirectional activation patching: forward (AI $\to $ human) flips 1--8\% of human samples to AI, $10\text {--}16\times $ above random; reverse (human $\to $ AI) flips 0.65--5.74\% of AI samples to human, $7\text {--}12\times $ above random}{figure.caption.1}{}}
